[Unit]
Description=Skaelia Prospection - application web
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=skaelia
WorkingDirectory=/opt/skaelia
Environment=PROSPECTION_PUBLIC=1
# 1 seul worker : l'app garde son état (recherche en cours) en mémoire.
ExecStart=/opt/skaelia/.venv/bin/gunicorn -w 1 --threads 8 --timeout 600 -b 127.0.0.1:5173 server:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
