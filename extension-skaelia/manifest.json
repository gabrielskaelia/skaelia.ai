{
  "manifest_version": 3,
  "name": "Skaelia Prospection — Envoi LinkedIn",
  "version": "1.2.1",
  "description": "Envoie directement les messages LinkedIn depuis l'outil de prospection Skaelia (ai.skaelia.com).",
  "permissions": ["storage", "cookies"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://ai.skaelia.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://ai.skaelia.com/*"],
      "js": ["content_app.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content_linkedin.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Skaelia Prospection",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
